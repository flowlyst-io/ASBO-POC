# Copy to .env.local and fill in. Everything has a working local default.
# NEVER put real keys in this file — it is committed. Real values go in .env.local (gitignored).

# Anthropic API key (server-side only). Required for real LLM runs.
# Leave empty and keep MOCK_AI=1 to run the whole pipeline with deterministic mock outputs.
ANTHROPIC_API_KEY=

# Postgres connection string (e.g. Neon). Leave empty to use the embedded
# PGlite database at ./.data/pg — zero setup for local dev.
DATABASE_URL=

# Vercel Blob read/write token. Leave empty to store uploads on the local
# filesystem at ./.data/blobs.
BLOB_READ_WRITE_TOKEN=

# Simple access gate for the shared POC link.
APP_ACCESS_CODE=letmein

# Shared secret for the internal pipeline advance chain (any random string).
INTERNAL_RUN_SECRET=dev-secret

# 1 = mock LLM responses (no key needed), 0 = real claude-haiku-4-5 calls.
MOCK_AI=1

# Max pipeline runs per day (protects API credits on a circulated link).
DAILY_RUN_CAP=25
