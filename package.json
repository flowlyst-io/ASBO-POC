{
  "name": "asbo-coe-review-poc",
  "version": "0.1.0",
  "private": true,
  "description": "ASBO Certificate of Excellence (COE) review automation POC — AI-prepared, page-cited ACFR findings with human-in-the-loop review.",
  "scripts": {
    "dev": "next dev",
    "build": "node --env-file-if-exists=.env.local --import tsx db/migrate.ts && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file-if-exists=.env.local --import tsx db/migrate.ts",
    "db:seed": "node --env-file-if-exists=.env.local --import tsx db/seed.ts",
    "stub-run": "node --env-file-if-exists=.env.local --import tsx scripts/stub-run.ts",
    "gate-e2e": "node --env-file-if-exists=.env.local --import tsx scripts/gate-decision-e2e.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@electric-sql/pglite": "^0.5.4",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/material-nextjs": "^9.1.1",
    "@vercel/blob": "^2.6.1",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.20",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  }
}
